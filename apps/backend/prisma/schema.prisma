generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SpawnPoint {
  id                  Int         @id @default(autoincrement())
  name                String
  category            String
  neighborhood        String
  address             String
  latitude            Float?
  longitude           Float?
  is_marta_accessible Boolean     @default(false)
  created_at          DateTime    @default(now())
  side_quests         SideQuest[]

  @@map("spawn_points")
}

model SideQuest {
  id                   Int        @id @default(autoincrement())
  spawn_point_id       Int
  name                 String
  description          String
  date                 String
  time                 String
  cost                 Float?
  is_free              Boolean    @default(true)
  is_beginner_friendly Boolean    @default(false)
  category             String
  tags                 String
  going_count          Int        @default(0)
  created_at           DateTime   @default(now())
  spawn_point          SpawnPoint @relation(fields: [spawn_point_id], references: [id])

  @@map("side_quests")
}
model Con {
  id          Int      @id @default(autoincrement())
  name        String
  start_date  String
  end_date    String
  venue       String
  neighborhood String
  size        String
  type        String
  ticket_url  String?
  created_at  DateTime @default(now())

  @@map("cons")
}