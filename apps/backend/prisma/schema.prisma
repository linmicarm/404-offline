generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}
model SpawnPoint {
  id                  Int         @id @default(autoincrement())
  name                String
  category            String
  neighborhood        String
  address             String
  latitude            Float?
  longitude           Float?
  hours               String?
  rating_sum          Int         @default(0)
  rating_count        Int         @default(0)
  is_marta_accessible Boolean     @default(false)
  created_at          DateTime    @default(now())
  side_quests         SideQuest[]
  checkin_count       Int         @default(0)
  suggestions         Suggestion[]
  image_url           String?
  description         String?

  @@map("spawn_points")
}

model SideQuest {
  id                   Int        @id @default(autoincrement())
  spawn_point_id       Int
  name                 String
  description          String
  date                 String
  time                 String
  cost                 Float?
  is_free              Boolean    @default(true)
  is_beginner_friendly Boolean    @default(false)
  is_recurring         Boolean    @default(false)
  recurrence           String?
  category             String
  tags                 String
  going_count          Int        @default(0)
  created_at           DateTime   @default(now())
  spawn_point          SpawnPoint @relation(fields: [spawn_point_id], references: [id])
  comments             Comment[]
  is_featured          Boolean    @default(false)
  image_url           String?

  @@map("side_quests")
}
model Con {
  id          Int      @id @default(autoincrement())
  name        String
  start_date  String
  end_date    String
  venue       String
  neighborhood String
  size        String
  type        String
  ticket_url  String?
  created_at  DateTime @default(now())

  @@map("cons")
}

model Comment {
  id            Int       @id @default(autoincrement())
  side_quest_id Int
  author_name   String
  body          String
  parent_id     Int?
  parent        Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentReplies")
  created_at    DateTime  @default(now())
  side_quest    SideQuest @relation(fields: [side_quest_id], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Suggestion {
  id             Int        @id @default(autoincrement())
  spawn_point_id Int
  author_name    String
  field          String
  current_value  String?
  suggested_value String
  note           String?
  status         String     @default("pending")
  created_at     DateTime   @default(now())
  spawn_point    SpawnPoint @relation(fields: [spawn_point_id], references: [id], onDelete: Cascade)

  @@map("suggestions")
}

